<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Work With Us — IndieCo</title>
<link rel="stylesheet" href="../css/base.css"/>
<link rel="stylesheet" href="../css/nav.css"/>
<style>
body { background: var(--dark); color: #f5f0e8; }

/* ── HERO ── */
.ww-hero {
  position: relative;
  padding: 140px 24px 80px;
  text-align: center;
  overflow: hidden;
  background: var(--dark);
}
canvas#ww-canvas { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.4; }
.ww-hero-inner { position: relative; z-index: 2; max-width: 680px; margin: 0 auto; }
.ww-eyebrow { font-size: 9px; letter-spacing: 0.38em; text-transform: uppercase; font-weight: 300; color: var(--gold); display: flex; align-items: center; justify-content: center; gap: 16px; margin-bottom: 28px; }
.ww-eyebrow::before, .ww-eyebrow::after { content: ''; display: block; width: 32px; height: 0.5px; background: var(--gold-light); }
.ww-title { font-family: var(--font-serif); font-size: clamp(2.4rem, 5.5vw, 4rem); font-weight: 300; line-height: 1.08; color: #f5f0e8; letter-spacing: -0.01em; margin-bottom: 22px; }
.ww-title em { font-style: italic; color: var(--gold); }
.ww-subtitle { font-size: 12px; font-weight: 300; color: rgba(245,240,232,0.45); letter-spacing: 0.1em; line-height: 1.9; }

/* ── PERKS GRID ── */
.perks-section { padding: 5rem 0 3rem; border-top: 0.5px solid rgba(245,240,232,0.08); }
.perks-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
.perk { padding: 2rem; border: 0.5px solid rgba(245,240,232,0.1); transition: border-color 0.3s, background 0.3s; }
.perk:hover { border-color: rgba(184,151,106,0.4); background: rgba(184,151,106,0.05); }
.perk-num { font-family: var(--font-serif); font-size: 0.85rem; font-weight: 300; color: rgba(245,240,232,0.3); margin-bottom: 0.75rem; display: block; }
.perk-title { font-size: 13px; font-weight: 400; color: rgba(245,240,232,0.85); margin-bottom: 4px; }
.perk-desc { font-size: 12.5px; font-weight: 300; color: rgba(245,240,232,0.45); line-height: 1.65; }

/* ── FORM ── */
.form-section { padding: 4rem 0 6rem; border-top: 0.5px solid rgba(245,240,232,0.08); }
.form-header { margin-bottom: 3rem; }
.form-header h2 { font-family: var(--font-serif); font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 300; line-height: 1.15; color: #f5f0e8; margin-bottom: 0.75rem; }
.form-header h2 em { font-style: italic; color: var(--gold); }
.form-header p { font-size: 13px; font-weight: 300; color: rgba(245,240,232,0.4); line-height: 1.75; }

/* Field styles */
.field { margin-bottom: 1.4rem; }
.field-label { display: block; font-size: 10px; font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,240,232,0.4); margin-bottom: 8px; }
.field-label sup { color: var(--gold); font-size: 11px; margin-left: 2px; }
input[type="text"],
input[type="email"],
textarea,
select {
  width: 100%;
  background: rgba(255,255,255,0.04);
  border: 0.5px solid rgba(245,240,232,0.12);
  color: #f5f0e8;
  font-family: var(--font-sans);
  font-size: 13px;
  font-weight: 300;
  letter-spacing: 0.04em;
  padding: 15px 16px;
  outline: none;
  transition: border-color 0.25s, background 0.25s;
  border-radius: 0;
  appearance: none;
}
input:focus, textarea:focus, select:focus { border-color: rgba(184,151,106,0.6); background: rgba(184,151,106,0.05); }
input::placeholder, textarea::placeholder { color: rgba(245,240,232,0.2); }
textarea { resize: vertical; min-height: 100px; line-height: 1.8; }
select { cursor: pointer; }
select option { background: #1c1a18; color: #f5f0e8; }
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

/* Checkboxes & Radios */
.radio-group, .check-group { display: flex; flex-direction: column; gap: 6px; }
.radio-opt, .check-opt {
  display: flex; align-items: flex-start; gap: 12px;
  cursor: pointer; padding: 12px 16px;
  border: 0.5px solid rgba(245,240,232,0.1);
  background: rgba(255,255,255,0.02);
  transition: border-color 0.2s, background 0.2s, transform 0.2s;
}
.radio-opt:hover, .check-opt:hover { border-color: rgba(184,151,106,0.4); background: rgba(184,151,106,0.04); transform: translateX(2px); }
.radio-opt input, .check-opt input { display: none; }
.radio-custom, .check-custom {
  width: 14px; height: 14px; min-width: 14px;
  border: 0.5px solid rgba(245,240,232,0.25);
  margin-top: 2px; position: relative;
  transition: border-color 0.2s;
  background: transparent; flex-shrink: 0;
}
.radio-custom { border-radius: 50%; }
.radio-opt input:checked ~ .radio-custom,
.check-opt input:checked ~ .check-custom { border-color: var(--gold); }
.radio-opt input:checked ~ .radio-custom::after {
  content: ''; position: absolute;
  inset: 3px; background: var(--gold); border-radius: 50%;
}
.check-opt input:checked ~ .check-custom::after {
  content: ''; position: absolute;
  top: 1px; left: 3px; width: 6px; height: 10px;
  border-right: 1px solid var(--gold); border-bottom: 1px solid var(--gold);
  transform: rotate(45deg);
}
.opt-label { font-size: 12.5px; font-weight: 300; color: rgba(245,240,232,0.5); line-height: 1.6; transition: color 0.2s; }
.radio-opt input:checked ~ .opt-label,
.check-opt input:checked ~ .opt-label { color: rgba(245,240,232,0.9); }
.radio-opt.selected { border-color: rgba(184,151,106,0.4); background: rgba(184,151,106,0.05); }

/* Form divider */
.form-divider { border: none; border-top: 0.5px solid rgba(245,240,232,0.08); margin: 2.5rem 0; }
.form-section-label { font-size: 9px; letter-spacing: 0.32em; text-transform: uppercase; font-weight: 300; color: var(--gold); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 14px; }
.form-section-label::after { content: ''; flex: 1; height: 0.5px; background: rgba(245,240,232,0.08); }

/* Submit */
.form-submit-row { margin-top: 2.5rem; display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 1.5rem; padding-top: 2rem; border-top: 0.5px solid rgba(245,240,232,0.08); }
.form-note { font-size: 12px; font-weight: 300; color: rgba(245,240,232,0.3); letter-spacing: 0.03em; line-height: 1.8; max-width: 340px; font-family: var(--font-serif); font-style: italic; }
.btn-submit {
  font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase; font-weight: 300;
  color: var(--dark); background: #f5f0e8; border: none; padding: 18px 44px;
  cursor: pointer; transition: background 0.25s, transform 0.2s;
  position: relative; overflow: hidden;
}
.btn-submit::before { content: ''; position: absolute; inset: 0; background: var(--gold); transform: scaleX(0); transform-origin: left; transition: transform 0.35s cubic-bezier(0.16,1,0.3,1); }
.btn-submit span { position: relative; z-index: 1; }
.btn-submit:hover::before { transform: scaleX(1); }
.btn-submit:hover { transform: translateY(-1px); }
.btn-submit:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
.btn-submit:disabled::before { display: none; }

#form-error { margin-top: 14px; font-size: 11px; color: #c87060; letter-spacing: 0.06em; display: none; padding: 10px 14px; border-left: 2px solid #c87060; background: rgba(200,112,96,0.06); }

/* Success */
.form-success { display: none; text-align: center; padding: 80px 40px; }
.form-success.visible { display: block; }
.success-icon { width: 52px; height: 52px; border: 0.5px solid var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 2rem; animation: scaleIn 0.5s ease both; }
@keyframes scaleIn { from{transform:scale(0.7);opacity:0} to{transform:scale(1);opacity:1} }
.success-icon::after { content: ''; width: 11px; height: 18px; border-right: 1px solid var(--gold); border-bottom: 1px solid var(--gold); transform: rotate(45deg) translate(-2px,-2px); display: block; }
.success-title { font-family: var(--font-serif); font-size: 2.4rem; font-weight: 300; color: #f5f0e8; margin-bottom: 1rem; }
.success-title em { font-style: italic; color: var(--gold); }
.success-body { font-size: 12px; font-weight: 300; color: rgba(245,240,232,0.4); letter-spacing: 0.07em; line-height: 2; }

@media (max-width: 620px) {
  .two-col { grid-template-columns: 1fr; }
  .perks-grid { grid-template-columns: 1fr; }
  .form-submit-row { flex-direction: column; }
}
</style>
</head>
<body>

<div id="nav-placeholder" data-dark="true"></div>

<!-- HERO -->
<div class="ww-hero">
  <canvas id="ww-canvas"></canvas>
  <div class="ww-hero-inner fade-up">
    <p class="ww-eyebrow">IndieCo</p>
    <h1 class="ww-title">Begin your<br><em>authority</em> journey.</h1>
    <p class="ww-subtitle">Tell us about your story. We'll take it from there.</p>
  </div>
</div>

<div class="page-wrap">

  <!-- PERKS -->
  <section class="perks-section">
    <div class="perks-grid">
      <div class="perk fade-up"><span class="perk-num">I</span><div class="perk-title">30-minute strategy session</div><p class="perk-desc">A focused conversation about your goals, your story, and the platform you want to build.</p></div>
      <div class="perk fade-up" style="transition-delay:0.1s"><span class="perk-num">II</span><div class="perk-title">Tailored positioning audit</div><p class="perk-desc">We identify where you stand today and what it takes to become the name in your field.</p></div>
      <div class="perk fade-up" style="transition-delay:0.2s"><span class="perk-num">III</span><div class="perk-title">Roadmap overview</div><p class="perk-desc">Walk away with a clear sense of the path — from idea to authority ecosystem.</p></div>
      <div class="perk fade-up" style="transition-delay:0.3s"><span class="perk-num">IV</span><div class="perk-title">No obligation</div><p class="perk-desc">This is a conversation, not a sales call. We only work with people we believe in.</p></div>
    </div>
  </section>

  <!-- FORM -->
  <section class="form-section">
    <div class="form-header fade-up">
      <h2>Begin your<br><em>authority journey.</em></h2>
      <p>Complete the form below and book a private call with our team. We respond within 24 hours.</p>
    </div>

    <form id="ww-form" novalidate>
      <!-- SECTION 1: ABOUT -->
      <div class="form-section-label">01 &nbsp; About you</div>
      <div class="two-col">
        <div class="field"><label class="field-label">First Name <sup>*</sup></label><input type="text" name="first_name" placeholder="Sofia" required/></div>
        <div class="field"><label class="field-label">Last Name <sup>*</sup></label><input type="text" name="last_name" placeholder="Reyes" required/></div>
      </div>
      <div class="field"><label class="field-label">Email Address <sup>*</sup></label><input type="email" name="email" placeholder="sofia@yourco.com" required/></div>
      <div class="two-col">
        <div class="field"><label class="field-label">Company / Organization</label><input type="text" name="company" placeholder="If applicable"/></div>
        <div class="field"><label class="field-label">Role / Title</label><input type="text" name="role" placeholder="e.g. Founder, CEO, Author"/></div>
      </div>
      <div class="field"><label class="field-label">Location <sup>*</sup></label><input type="text" name="location" placeholder="City, Country" required/></div>

      <hr class="form-divider"/>

      <!-- SECTION 2: YOUR EXPERTISE -->
      <div class="form-section-label">02 &nbsp; Your expertise</div>
      <div class="field">
        <label class="field-label">Your field / industry <sup>*</sup></label>
        <input type="text" name="field" placeholder="e.g. Finance, Health, Technology, Law" required/>
      </div>
      <div class="field">
        <label class="field-label">Professional background & area of expertise <sup>*</sup></label>
        <textarea name="background" placeholder="What are you known for? What have you spent years thinking or working on?" required></textarea>
      </div>

      <hr class="form-divider"/>

      <!-- SECTION 3: GOALS -->
      <div class="form-section-label">03 &nbsp; What brings you here?</div>
      <div class="field">
        <label class="field-label">Primary goal <sup>*</sup></label>
        <select name="goal" required>
          <option value="" disabled selected>Select your primary goal</option>
          <option>Book publishing & bestseller strategy</option>
          <option>Speaking & global stage placement</option>
          <option>O1A / immigration documentation</option>
          <option>Media features & PR</option>
          <option>Thought leadership positioning</option>
          <option>Brand & revenue strategy</option>
          <option>Full authority ecosystem</option>
        </select>
      </div>
      <div class="field">
        <label class="field-label">Which package interests you?</label>
        <div class="radio-group">
          <label class="radio-opt"><input type="radio" name="package" value="Legacy Authority System"/><span class="radio-custom"></span><span class="opt-label">Legacy Authority System — Premier</span></label>
          <label class="radio-opt"><input type="radio" name="package" value="Industry Authority Engine"/><span class="radio-custom"></span><span class="opt-label">Industry Authority Engine — Scaled</span></label>
          <label class="radio-opt"><input type="radio" name="package" value="Lifestyle Author System"/><span class="radio-custom"></span><span class="opt-label">Lifestyle Author System — Entry</span></label>
          <label class="radio-opt"><input type="radio" name="package" value="Standard Services"/><span class="radio-custom"></span><span class="opt-label">Standard Services</span></label>
          <label class="radio-opt"><input type="radio" name="package" value="Undecided"/><span class="radio-custom"></span><span class="opt-label">Undecided — I'd like to explore on a call</span></label>
        </div>
      </div>

      <hr class="form-divider"/>

      <!-- SECTION 4: SCHEDULE -->
      <div class="form-section-label">04 &nbsp; Schedule a call</div>
      <p style="font-size:12px;color:rgba(245,240,232,0.35);line-height:1.8;margin-bottom:1.5rem;font-style:italic;font-family:var(--font-serif)">Select a time below to secure your 1:1 session with our team.</p>
      <div class="calendly-inline-widget"
           data-url="https://calendly.com/indieco/1-1-working-session-with-leah"
           style="min-width:320px;height:700px;border:0.5px solid rgba(245,240,232,0.1);">
      </div>

      <hr class="form-divider"/>

      <!-- SECTION 5: FINAL -->
      <div class="form-section-label">05 &nbsp; Anything else?</div>
      <div class="field">
        <label class="field-label">Additional notes</label>
        <textarea name="notes" placeholder="Your story, your goals, your questions — anything relevant."></textarea>
      </div>
      <div class="field">
        <label class="field-label">How did you find us?</label>
        <div class="radio-group">
          <label class="radio-opt"><input type="radio" name="referral" value="LinkedIn"/><span class="radio-custom"></span><span class="opt-label">LinkedIn</span></label>
          <label class="radio-opt"><input type="radio" name="referral" value="IndieCo reached out"/><span class="radio-custom"></span><span class="opt-label">IndieCo reached out to me</span></label>
          <label class="radio-opt"><input type="radio" name="referral" value="Referral"/><span class="radio-custom"></span><span class="opt-label">Referral from someone I know</span></label>
          <label class="radio-opt"><input type="radio" name="referral" value="Internet search"/><span class="radio-custom"></span><span class="opt-label">Internet / search</span></label>
          <label class="radio-opt"><input type="radio" name="referral" value="Other"/><span class="radio-custom"></span><span class="opt-label">Other</span></label>
        </div>
      </div>

      <div class="form-submit-row">
        <p class="form-note">Your responses are confidential and reviewed personally by the IndieCo team. We will be in touch within 24 hours.</p>
        <button type="submit" class="btn-submit" id="submit-btn"><span>Submit &rarr;</span></button>
      </div>
      <div id="form-error">Please complete all required fields before submitting.</div>
    </form>

    <div class="form-success" id="form-success">
      <div class="success-icon"></div>
      <h2 class="success-title">Your story is<br><em>in our hands.</em></h2>
      <p class="success-body">Thank you for reaching out. The IndieCo team will<br>review your submission and be in touch within 24 hours.</p>
    </div>
  </section>
</div>

<div id="footer-placeholder" data-dark="true"></div>

<script src="https://assets.calendly.com/assets/external/widget.js" async></script>
<script src="../js/nav.js"></script>
<script src="../js/forms.js"></script>
<script>
/* CANVAS */
(function(){
  const cv=document.getElementById('ww-canvas');
  const ctx=cv.getContext('2d');
  function resize(){cv.width=cv.offsetWidth;cv.height=cv.offsetHeight;}
  resize(); window.addEventListener('resize',resize);
  const N=36, pts=Array.from({length:N},()=>({
    x:Math.random()*cv.width, y:Math.random()*cv.height,
    vx:(Math.random()-0.5)*0.18, vy:(Math.random()-0.5)*0.12,
    r:Math.random()*1.2+0.4
  }));
  function draw(){
    const W=cv.width,H=cv.height;
    ctx.clearRect(0,0,W,H);
    pts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;if(p.x<0||p.x>W)p.vx*=-1;if(p.y<0||p.y>H)p.vy*=-1;});
    for(let i=0;i<N;i++){for(let j=i+1;j<N;j++){
      const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<110){ctx.beginPath();ctx.strokeStyle=`rgba(184,157,122,${(1-d/110)*0.12})`;ctx.lineWidth=0.5;ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);ctx.stroke();}
    }}
    pts.forEach((p,i)=>{ctx.beginPath();ctx.fillStyle=i%4===0?`rgba(184,157,122,0.5)`:`rgba(28,26,23,0.08)`;ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fill();});
    requestAnimationFrame(draw);
  }
  draw();
})();

/* RADIO SELECTION VISUAL */
document.querySelectorAll('.radio-opt').forEach(opt => {
  opt.addEventListener('click', () => {
    const input = opt.querySelector('input');
    if (!input) return;
    document.querySelectorAll(`input[name="${input.name}"]`).forEach(r => {
      r.closest('.radio-opt').classList.remove('selected');
    });
    opt.classList.add('selected');
  });
});

/* CALENDLY BOOKED FLAG */
var calendlyBooked = false;
window.addEventListener('message', function(e) {
  if (e.data && e.data.event && e.data.event.indexOf('calendly.event_scheduled') === 0) {
    calendlyBooked = true;
  }
});

/* FORM SUBMIT */
attachFormHandler(document.getElementById('ww-form'), {
  validate: function() {
    const required = ['first_name', 'last_name', 'email', 'location', 'background', 'field'];
    for (const name of required) {
      const el = document.querySelector(`[name="${name}"]`);
      if (!el || !el.value.trim()) {
        const err = document.getElementById('form-error');
        err.style.display = 'block';
        err.textContent = 'Please complete all required fields before submitting.';
        el && el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return false;
      }
    }
    if (!calendlyBooked) {
      const err = document.getElementById('form-error');
      err.style.display = 'block';
      err.textContent = 'Please schedule your consultation via the calendar above before submitting.';
      document.querySelector('.calendly-inline-widget').scrollIntoView({ behavior: 'smooth' });
      return false;
    }
    document.getElementById('form-error').style.display = 'none';
    return true;
  },
  onSuccess: function() {
    document.getElementById('ww-form').style.display = 'none';
    const success = document.getElementById('form-success');
    success.classList.add('visible');
    success.scrollIntoView({ behavior: 'smooth' });
  },
  onError: function() {
    const err = document.getElementById('form-error');
    err.style.display = 'block';
    err.textContent = 'Something went wrong. Please try again or email us directly at contact@indieco.com.co';
  }
});
</script>
</body>
</html>
